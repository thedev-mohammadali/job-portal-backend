model Application {
    id                 String            @id @default(uuid()) @db.Uuid
    jobId              String            @map("job_id") @db.Uuid
    jobSeekerProfileId String            @map("job_seeker_profile_id") @db.Uuid
    coverLetter        String            @map("cover_letter")
    resumeUrl          String            @map("resume_url")
    status             ApplicationStatus
    appliedAt          DateTime          @default(now()) @map("applied_at") @db.Timestamptz(3)
    updatedAt          DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

    job              Job              @relation(fields: [jobId], references: [id])
    jobSeekerProfile JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id])

    @@unique([jobId, jobSeekerProfileId])
    @@index([jobSeekerProfileId])
    @@index([jobId, status])
    @@map("applications")
}
